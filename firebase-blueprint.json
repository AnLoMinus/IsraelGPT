{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat session with history",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "messages": { "type": "array" },
        "timestamp": { "type": "number" }
      },
      "required": ["userId", "title", "messages", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": { "$ref": "ChatSession" },
      "description": "User chat sessions"
    }
  }
}
